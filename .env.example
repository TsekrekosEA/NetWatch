# ─── Backend ───────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./netwatch.db
CAPTURE_TOKEN=change-me-in-production
ML_MODELS_PATH=./ml/models
LOG_LEVEL=INFO

# Stage 1: Statistical baseline
STAT_THRESHOLD=3.5
ROLLING_WINDOW_SIZE=1000
STAT_WARMUP=30
SEVERITY_MEDIUM_THRESHOLD=3
SEVERITY_HIGH_THRESHOLD=6

# Stage 2: ML classifier
IF_THRESHOLD=-0.2
RF_CONFIDENCE_THRESHOLD=0.4

# Alert rate limiting (seconds per src_ip+category pair)
ALERT_RATE_LIMIT_SECONDS=10

# ─── Capture service ──────────────────────────────────────
BACKEND_URL=http://backend:8000
INTERFACE=eth0
DEMO_MODE=true
FLOW_TIMEOUT=120
MAX_FLOW_PACKETS=10000
BPF_FILTER=ip

# PCAP replay mode (set DEMO_MODE=false to use)
# REPLAY_PCAP=/data/capture.pcap
# REPLAY_SPEED=10.0
# REPLAY_LOOP=false

# ─── Frontend ─────────────────────────────────────────────
VITE_API_URL=http://localhost:8001
VITE_WS_URL=ws://localhost:8001
